{
  "manifest_version": 3,
  "name": "Local Query Bridge",
  "version": "0.1.0",
  "description": "Polls a local screenshot bridge and submits tasks into ChatGPT.",
  "permissions": [
    "activeTab",
    "scripting",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://192.168.0.215/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Local Query Bridge"
  }
}
